# CloudGuard Pro CSPM v3 — Environment Configuration
# Aniza Corp | Shahryar Jahangir
# Copy this to .env and edit before starting.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info
LOG_DIR=logs

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — single file, no setup needed)
# DATABASE_URL=sqlite:///./cspm.db
# PostgreSQL (for production / multi-worker)
# DATABASE_URL=postgresql://user:password@localhost:5432/cspm

# ── Demo Data ─────────────────────────────────────────────────────────────────
# Set to false to start with an empty database (no sample assets or findings).
# Set to true  to seed 40 demo assets and ~50 findings on first startup.
SEED_DEMO_DATA=true

# ── AWS Credentials (leave blank to use demo scan mode) ───────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Azure Credentials ─────────────────────────────────────────────────────────
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

# ── GCP Credentials ───────────────────────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=

# ── IBM Cloud ─────────────────────────────────────────────────────────────────
# IBMCLOUD_API_KEY=

# ── OCI ───────────────────────────────────────────────────────────────────────
# OCI credentials are read from ~/.oci/config (OCI CLI format)
